# Server
PORT=8001

# Same optional Postgres check as cv-microservice
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_hr

# OpenAI — embeddings (LangChain OpenAIEmbeddings)
OPENAI_API_KEY=
# Must match your Pinecone index dimension (text-embedding-3-small => 1536)
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
PINECONE_NAMESPACE=vacancies

# Llama via Ollama (LangChain ChatOllama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
